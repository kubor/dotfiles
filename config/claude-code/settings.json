{
  "respectGitignore": true,
  "env": {
    "DISABLE_AUTOUPDATER": "0",
    "CLOUD_ML_REGION": "us-east5",
    "CLAUDE_CODE_USE_VERTEX": "true",
    "ANTHROPIC_MODEL": "claude-opus-4-6",
    "ANTHROPIC_VERTEX_PROJECT_ID": "caddi-ai-tools-dev",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-6",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4-5",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-sonnet-4-6",
    "ENABLE_TOOL_SEARCH": "1"
  },
  "permissions": {
    "allow": [
      "List(*)",
      "Fetch(https://*)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(mv:*)",
      "Bash(make:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mise:*)",
      "Bash(hyperfine:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(sed:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(ps:*)",
      "Bash(which:*)",
      "Bash(whoami:*)",
      "Bash(pwd:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(date:*)",
      "Bash(ln:*)",
      "Bash(touch:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(diff:*)",
      "Bash(brew:*)",
      "Bash(npm:*)",
      "Bash(yarn:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr create:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh issue view:*)",
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "Bash(git push:*)",
      "Bash(git remote set-url:*)",
      "Bash(git pull:*)",
      "Bash(git reset:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git worktree:*)",
      "Bash(git branch:*)",
      "mcp__github__create_pull_request",
      "mcp__github__get_issue",
      "mcp__github__add_issue_comment",
      "mcp__github__get_issue_comments",
      "Bash(claude config:*)",
      "Bash(uv:*)",
      "Bash(git commit:*)",
      "Bash(docker:*)",
      "Bash(terraform init)",
      "Bash(terraform plan)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:huggingface.co)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:arxiv.org)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:python.org)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:pytorch.org)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:kaggle.com)",
      "Bash(cargo:*)",
      "Bash(RUSTUP_TOOLCHAIN=stable cargo:*)",
      "Bash(rustup:*)",
      "Bash(rustc:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(gh api:*)",
      "Bash(gh repo view:*)",
      "Bash(gh issue list:*)",
      "Bash(git remote:*)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:crates.io)"
    ],
    "defaultMode": "plan",
    "deny": [
      "Bash(git push origin main)",
      "Bash(pip:*)",
      "Bash(rsync:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rm -rf:*)",
      "Bash(rm:*)",
      "Bash(sudo:*)",
      "Bash(chown root:*)",
      "Bash(chown:*)",
      "Bash(chgrp:*)",
      "Bash(chmod:*)",
      "Read(.env.*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Write(.env*)",
      "Write(**/secrets/**)"
    ]
  },
  "model": "opus",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMPDIR\" ] && mkdir -p \"$TMPDIR\" && echo 'OK' || echo 'TMPDIR not set'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/Users/ryuichi_kubo/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "usage-collector@awesome-claude-marketplace": true,
    "commit-commands@claude-plugins-official": true,
    "claude-bench@awesome-claude-marketplace": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "awesome-claude-marketplace": {
      "source": {
        "source": "git",
        "url": "git@github.com:caddi-sandbox/awesome-claude-marketplace.git"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "autoUpdatesChannel": "stable",
  "plansDirectory": "./plans",
  "memory": "auto",
  "editorMode": "vscode",
  "detectSecrets": true,
  "maxTokens": 8192,
  "temperature": 0.7
}
